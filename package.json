{
  "name": "dungeon-crawler-rpg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "[ -f .claude/hooks/pre-commit.sh ] && cp .claude/hooks/pre-commit.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit || true",
    "build": "pnpm -r run build",
    "test": "VITEST_MAX_THREADS=2 vitest run --reporter=./scripts/reporters/vitest-quiet.js --bail 1",
    "test:verbose": "VITEST_MAX_THREADS=2 vitest run",
    "test:changed": "VITEST_MAX_THREADS=2 vitest run --reporter=./scripts/reporters/vitest-quiet.js --changed",
    "test:balance": "NODE_OPTIONS=--max-old-space-size=2048 VITEST_MAX_THREADS=2 vitest run --include '**/*.balance.test.ts'",
    "test:watch": "vitest",
    "dev:server": "pnpm --filter @dungeon/server dev",
    "dev:web": "pnpm --filter @dungeon/web dev",
    "dev": "pnpm run dev:server & pnpm run dev:web",
    "clean:logs": "rm -rf .validate-logs && mkdir -p .validate-logs",
    "check:fast": "pnpm run check:tracked-artifacts && pnpm run check:audit-guardrails && pnpm run check:three-animations && node scripts/check-workspace-wiring.mjs && pnpm run lint:prepare && pnpm run lint:eslint:cached && pnpm run lint:types:all",
    "validate": "pnpm run clean:logs && pnpm run clean:zone-identifiers && pnpm generate:indexes && pnpm run check:tracked-artifacts && pnpm run check:audit-guardrails && pnpm run check:three-animations && node scripts/check-workspace-wiring.mjs && pnpm run check:ability-contracts && pnpm lint && pnpm test && pnpm build && pnpm run check:exports",
    "validate:quick": "pnpm run clean:logs && pnpm run clean:zone-identifiers && pnpm generate:indexes && pnpm run check:fast && pnpm run check:ability-contracts && pnpm test:changed && pnpm build",
    "lint": "pnpm lint:prepare && pnpm lint:eslint:cached && pnpm run lint:types:all",
    "lint:prepare": "pnpm --filter eslint-plugin-dungeon build",
    "lint:eslint": "pnpm run lint:eslint:typed && pnpm run lint:eslint:typed:tests && pnpm run lint:eslint:untyped",
    "lint:structural": "LINT_STRUCTURAL=true pnpm run lint:eslint",
    "lint:structural:hotspots": "LINT_STRUCTURAL=true pnpm exec eslint \"packages/game-core/src/engine/**/*.ts\" \"packages/presenter/src/builders/**/*.ts\" \"apps/server/src/app.ts\" \"apps/server/src/routes/**/*.ts\" \"apps/server/src/services/**/*.ts\" \"apps/web/src/App.tsx\" \"apps/web/src/hooks/**/*.ts\" \"apps/web/src/animation-runtime/**/*.ts\" \"apps/web/src/testing/e2e-bridge.ts\"",
    "lint:eslint:cached": "pnpm run lint:eslint:typed:cached && pnpm run lint:eslint:typed:tests:cached && pnpm run lint:eslint:untyped:cached",
    "lint:eslint:fix": "pnpm exec eslint \"apps/*/src/**/*.{ts,tsx}\" \"packages/*/src/**/*.ts\" --fix && pnpm exec eslint \"scripts/**/*.ts\" \"tests/**/*.ts\" \"**/*.test.ts\" \"**/*.property.test.ts\" \"playwright.config.ts\" \"vitest.config.ts\" \"apps/*/vite.config.ts\" \"apps/*/vitest.config.ts\" \"apps/*/vitest.setup.ts\" \"packages/*/vitest.config.ts\" \"packages/eslint-plugin-dungeon/src/**/*.ts\" --fix",
    "lint:eslint:typed": "pnpm exec eslint \"apps/*/src/**/*.{ts,tsx}\" \"packages/*/src/**/*.ts\"",
    "lint:eslint:typed:cached": "pnpm exec eslint \"apps/*/src/**/*.{ts,tsx}\" \"packages/*/src/**/*.ts\" --cache --cache-location .eslintcache-typed",
    "lint:eslint:untyped": "pnpm exec eslint \"scripts/**/*.ts\" \"tests/**/*.ts\" \"**/*.test.ts\" \"**/*.property.test.ts\" \"playwright.config.ts\" \"vitest.config.ts\" \"apps/*/vite.config.ts\" \"apps/*/vitest.config.ts\" \"apps/*/vitest.setup.ts\" \"packages/*/vitest.config.ts\" \"packages/eslint-plugin-dungeon/src/**/*.ts\"",
    "lint:eslint:untyped:cached": "pnpm exec eslint \"scripts/**/*.ts\" \"tests/**/*.ts\" \"**/*.test.ts\" \"**/*.property.test.ts\" \"playwright.config.ts\" \"vitest.config.ts\" \"apps/*/vite.config.ts\" \"apps/*/vitest.config.ts\" \"apps/*/vitest.setup.ts\" \"packages/*/vitest.config.ts\" \"packages/eslint-plugin-dungeon/src/**/*.ts\" --cache --cache-location .eslintcache-untyped",
    "lint:clean": "rm -f .eslintcache .eslintcache-typed .eslintcache-untyped && find . -name '.eslintcache*' -delete",
    "lint:types": "NODE_OPTIONS=--max-old-space-size=2048 tsc -b apps/web/tsconfig.json apps/server/tsconfig.json",
    "lint:types:src": "NODE_OPTIONS=--max-old-space-size=2048 tsc -b apps/web/tsconfig.json apps/server/tsconfig.json packages/game-contracts/tsconfig.json packages/game-core/tsconfig.json packages/content/tsconfig.json packages/presenter/tsconfig.json",
    "lint:types:tests": "NODE_OPTIONS=--max-old-space-size=2048 node scripts/typecheck-tests.mjs",
    "lint:types:all": "pnpm run lint:types:src && pnpm run lint:types:tests",
    "lint:eslint:typed:tests": "pnpm exec eslint \"apps/*/src/**/*.test.{ts,tsx}\" \"packages/*/src/**/*.test.ts\" \"packages/*/src/**/*.property.test.ts\" \"tests/**/*.ts\"",
    "lint:eslint:typed:tests:cached": "pnpm exec eslint \"apps/*/src/**/*.test.{ts,tsx}\" \"packages/*/src/**/*.test.ts\" \"packages/*/src/**/*.property.test.ts\" \"tests/**/*.ts\" --cache --cache-location .eslintcache-typed-tests",
    "clean": "pnpm -r run clean",
    "clean:artifacts": "pnpm -r exec rm -rf dist .turbo && find . -name '*.tsbuildinfo' -not -path '*/node_modules/*' -delete",
    "clean:zone-identifiers": "find . -name '*:Zone.Identifier' -delete",
    "check:tracked-artifacts": "node scripts/check-tracked-artifacts.mjs",
    "check:audit-guardrails": "node scripts/check-audit-guardrails.mjs",
    "check:three-animations": "pnpm exec tsx --tsconfig scripts/tsconfig.json scripts/guardrails/check-three-animation-coverage.ts",
    "check:ability-contracts": "pnpm exec tsx --tsconfig scripts/tsconfig.json scripts/check-ability-contracts.ts",
    "check:workspace-wiring": "node scripts/check-workspace-wiring.mjs",
    "check:exports": "node scripts/check-package-exports.mjs",
    "ci:verify": "pnpm run clean:zone-identifiers && pnpm run clean:artifacts && pnpm install --frozen-lockfile && pnpm build && pnpm run check:exports && pnpm test:verbose",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep \"@smoke\"",
    "test:e2e:scenario": "playwright test --grep \"scenario\"",
    "test:e2e:full": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit:tests": "pnpm exec tsx --tsconfig scripts/tsconfig.json scripts/audit-tests.ts",
    "test:docker": "bash scripts/test-docker-build.sh",
    "balance": "pnpm exec tsx --tsconfig scripts/tsconfig.json scripts/balance/index.ts",
    "balance:lm": "pnpm exec tsx --tsconfig scripts/tsconfig.json scripts/balance/index.ts --strategy lm --runs 50",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:restart": "docker-compose down && docker-compose up -d --build",
    "parse-atlas": "tsx --tsconfig scripts/tsconfig.json scripts/parse-dawnlike-atlas.ts",
    "generate:indexes": "tsx --tsconfig scripts/tsconfig.json scripts/generate-indexes.ts",
    "goofy:sync": "node scripts/sync-goofy-profile.mjs",
    "goofy:check": "node scripts/sync-goofy-profile.mjs --check",
    "goofy:model:install": "node scripts/install-goofy-ollama-models.mjs",
    "goofy:model:test": "vitest run --config tests/vitest.config.ts tests/integration/goofy-local-model.integration.test.ts",
    "goofy:model:eval": "node scripts/run-goofy-model-evals.mjs",
    "skills:generate": "node scripts/generate-repo-skills.mjs",
    "skills:check": "node scripts/check-repo-skills.mjs",
    "skill:model-orchestrator:sync": "node scripts/sync-model-orchestrator-skill.mjs",
    "skill:model-orchestrator:check": "node scripts/sync-model-orchestrator-skill.mjs --check",
    "skill:model-orchestrator:uninstall": "node scripts/sync-model-orchestrator-skill.mjs --uninstall"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.1.0",
    "@playwright/test": "^1.58.2",
    "@types/eslint": "^9.6.1",
    "@types/estree": "^1.0.8",
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/eslint-plugin": "^1.6.13",
    "eslint": "^9.39.4",
    "eslint-plugin-dungeon": "workspace:*",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fast-check": "^4.0.0",
    "jsdom": "^24.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
