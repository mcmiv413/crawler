{
  "name": "dungeon-crawler-rpg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "VITEST_MAX_THREADS=2 vitest run --reporter=./scripts/reporters/vitest-quiet.js --bail 1",
    "test:verbose": "VITEST_MAX_THREADS=2 vitest run",
    "test:changed": "VITEST_MAX_THREADS=2 vitest run --reporter=./scripts/reporters/vitest-quiet.js --changed",
    "test:balance": "NODE_OPTIONS=--max-old-space-size=2048 VITEST_MAX_THREADS=2 vitest run --include '**/*.balance.test.ts'",
    "test:watch": "vitest",
    "dev:server": "LM_HOST=192.168.1.38 LM_PORT=1234 pnpm --filter @dungeon/server dev",
    "dev:web": "pnpm --filter @dungeon/web dev",
    "dev": "pnpm run dev:server & pnpm run dev:web",
    "validate": "pnpm lint && pnpm test && pnpm build",
    "validate:quick": "pnpm lint:eslint:cached --quiet && pnpm test:changed && pnpm build",
    "lint": "pnpm lint:prepare && pnpm lint:eslint:cached && pnpm run lint:types:all",
    "lint:prepare": "pnpm --filter eslint-plugin-dungeon build",
    "lint:eslint": "pnpm run lint:eslint:typed && pnpm run lint:eslint:typed:tests && pnpm run lint:eslint:untyped",
    "lint:eslint:cached": "pnpm run lint:eslint:typed:cached && pnpm run lint:eslint:typed:tests:cached && pnpm run lint:eslint:untyped:cached",
    "lint:eslint:fix": "pnpm exec eslint \"apps/*/src/**/*.{ts,tsx}\" \"packages/*/src/**/*.ts\" --fix && pnpm exec eslint \"scripts/**/*.ts\" \"tests/**/*.ts\" \"**/*.test.ts\" \"**/*.property.test.ts\" \"playwright.config.ts\" \"vitest.workspace.ts\" \"apps/*/vite.config.ts\" \"apps/*/vitest.config.ts\" \"apps/*/vitest.setup.ts\" \"packages/*/vitest.config.ts\" --fix",
    "lint:eslint:typed": "pnpm exec eslint \"apps/*/src/**/*.{ts,tsx}\" \"packages/*/src/**/*.ts\"",
    "lint:eslint:typed:cached": "pnpm exec eslint \"apps/*/src/**/*.{ts,tsx}\" \"packages/*/src/**/*.ts\" --cache --cache-location .eslintcache-typed --quiet",
    "lint:eslint:untyped": "pnpm exec eslint \"scripts/**/*.ts\" \"tests/**/*.ts\" \"**/*.test.ts\" \"**/*.property.test.ts\" \"playwright.config.ts\" \"vitest.workspace.ts\" \"apps/*/vite.config.ts\" \"apps/*/vitest.config.ts\" \"apps/*/vitest.setup.ts\" \"packages/*/vitest.config.ts\"",
    "lint:eslint:untyped:cached": "pnpm exec eslint \"scripts/**/*.ts\" \"tests/**/*.ts\" \"**/*.test.ts\" \"**/*.property.test.ts\" \"playwright.config.ts\" \"vitest.workspace.ts\" \"apps/*/vite.config.ts\" \"apps/*/vitest.config.ts\" \"apps/*/vitest.setup.ts\" \"packages/*/vitest.config.ts\" --cache --cache-location .eslintcache-untyped --quiet",
    "lint:clean": "rm -f .eslintcache .eslintcache-typed .eslintcache-untyped && find . -name '.eslintcache*' -delete",
    "lint:types": "NODE_OPTIONS=--max-old-space-size=2048 tsc -b apps/web/tsconfig.json apps/server/tsconfig.json",
    "lint:types:src": "NODE_OPTIONS=--max-old-space-size=2048 tsc -b apps/web/tsconfig.json apps/server/tsconfig.json packages/game-contracts/tsconfig.json packages/game-core/tsconfig.json packages/content/tsconfig.json packages/presenter/tsconfig.json",
    "lint:types:tests": "NODE_OPTIONS=--max-old-space-size=2048 node scripts/typecheck-tests.mjs",
    "lint:types:all": "pnpm run lint:types:src && pnpm run lint:types:tests",
    "lint:eslint:typed:tests": "pnpm exec eslint \"apps/*/src/**/*.test.{ts,tsx}\" \"packages/*/src/**/*.test.ts\" \"packages/*/src/**/*.property.test.ts\" \"tests/**/*.ts\"",
    "lint:eslint:typed:tests:cached": "pnpm exec eslint \"apps/*/src/**/*.test.{ts,tsx}\" \"packages/*/src/**/*.test.ts\" \"packages/*/src/**/*.property.test.ts\" \"tests/**/*.ts\" --cache --cache-location .eslintcache-typed-tests --quiet",
    "clean": "pnpm -r run clean",
    "clean:artifacts": "pnpm -r exec rm -rf dist .turbo && find . -name '*.tsbuildinfo' -not -path '*/node_modules/*' -delete",
    "check:exports": "node scripts/check-package-exports.mjs",
    "ci:verify": "pnpm run clean:artifacts && pnpm install --frozen-lockfile && pnpm build && pnpm run check:exports && pnpm test --run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:docker": "bash scripts/test-docker-build.sh",
    "balance": "LM_HOST=192.168.1.38 LM_PORT=1234 pnpm exec tsx --tsconfig scripts/tsconfig.json scripts/balance/index.ts",
    "balance:lm": "LM_HOST=192.168.1.38 LM_PORT=1234 pnpm exec tsx --tsconfig scripts/tsconfig.json scripts/balance/index.ts --strategy lm --runs 50",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:restart": "docker-compose down && docker-compose up -d --build",
    "parse-atlas": "tsx --tsconfig scripts/tsconfig.json scripts/parse-dawnlike-atlas.ts"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.1.0",
    "@playwright/test": "^1.58.2",
    "@types/eslint": "^9.6.1",
    "@types/estree": "^1.0.8",
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/eslint-plugin": "^1.6.13",
    "eslint": "^9.39.4",
    "eslint-plugin-dungeon": "workspace:*",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fast-check": "^4.0.0",
    "jsdom": "^24.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
