{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": false,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@dungeon/contracts": ["./packages/game-contracts/src/index.ts"],
      "@dungeon/contracts/*": ["./packages/game-contracts/src/*"],
      "@dungeon/core": ["./packages/game-core/src/index.ts"],
      "@dungeon/core/ai/ai-service": ["./packages/game-core/src/ai/ai-service.ts"],
      "@dungeon/core/ai/prompt-builders": ["./packages/game-core/src/ai/prompt-builders.ts"],
      "@dungeon/core/testing": ["./packages/game-core/src/testing/index.ts"],
      "@dungeon/core/utils/pathfinding": ["./packages/game-core/src/utils/pathfinding.ts"],
      "@dungeon/content": ["./packages/content/src/index.ts"],
      "@dungeon/content/*": ["./packages/content/src/*"],
      "@dungeon/presenter": ["./packages/presenter/src/index.ts"],
      "@dungeon/presenter/*": ["./packages/presenter/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
