{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "buildCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm build",
  "rewrites": [
    {"source": "/(.*)", "destination": "/api"}
  ],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "*": false
    }
  }
}


