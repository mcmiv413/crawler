{
  "name": "@dungeon/presenter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./targeting": {
      "types": "./dist/targeting/index.d.ts",
      "import": "./dist/targeting/index.js",
      "default": "./dist/targeting/index.js"
    },
    "./testing/feature-chain-helpers": {
      "types": "./dist/testing/feature-chain-helpers.d.ts",
      "import": "./dist/testing/feature-chain-helpers.js",
      "default": "./dist/testing/feature-chain-helpers.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@dungeon/contracts": "workspace:*",
    "@dungeon/content": "workspace:*",
    "@dungeon/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
