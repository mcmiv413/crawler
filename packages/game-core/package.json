{
  "name": "@dungeon/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ai/ai-service": {
      "import": "./dist/ai/ai-service.js",
      "default": "./dist/ai/ai-service.js",
      "types": "./dist/ai/ai-service.d.ts"
    },
    "./ai/ai-service.js": {
      "import": "./dist/ai/ai-service.js",
      "default": "./dist/ai/ai-service.js",
      "types": "./dist/ai/ai-service.d.ts"
    },
    "./ai/prompt-builders": {
      "import": "./dist/ai/prompt-builders.js",
      "default": "./dist/ai/prompt-builders.js",
      "types": "./dist/ai/prompt-builders.d.ts"
    },
    "./ai/prompt-builders.js": {
      "import": "./dist/ai/prompt-builders.js",
      "default": "./dist/ai/prompt-builders.js",
      "types": "./dist/ai/prompt-builders.d.ts"
    },
    "./utils/pathfinding": {
      "import": "./dist/utils/pathfinding.js",
      "default": "./dist/utils/pathfinding.js",
      "types": "./dist/utils/pathfinding.d.ts"
    },
    "./utils/pathfinding.js": {
      "import": "./dist/utils/pathfinding.js",
      "default": "./dist/utils/pathfinding.js",
      "types": "./dist/utils/pathfinding.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@dungeon/contracts": "workspace:*",
    "@dungeon/content": "workspace:*",
    "@dungeon/presenter": "workspace:*",
    "rot-js": "^2.2.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "fast-check": "^4.0.0"
  }
}
