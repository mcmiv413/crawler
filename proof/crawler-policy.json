{
  "schemaVersion": "crawler-proof-policy/v1",
  "challengeSchemaVersion": "crawler-proof-challenge/v1",
  "minimumVerifierVersion": "0.4.2",
  "verifier": {
    "implementationLocation": "external-protected-repository",
    "release": {
      "repository": "github.com/mcmiv413/agent-verifier",
      "tag": "v0.4.2",
      "sourceSha": "31a195d774982ae04c4e157c0bbd5c3b0ff33515",
      "artifactDigest": "ab25db52939959362eaca3c4dc8374228c0e12c2532719e90a78ecb3a9591318"
    },
    "minimumClientVersion": "0.4.2"
  },
  "authority": {
    "localEvidence": "advisory",
    "authoritativeValidation": "remote-verifier-service",
    "mergeAdmission": "installed-github-app",
    "nativeGitHubActions": "not-authoritative"
  },
  "protectedBranches": [
    {
      "name": "main",
      "updatesAllowedOnlyFrom": "installed-github-app",
      "forcePush": false,
      "humanDirectPush": false,
      "nativeSquashMerge": false,
      "nativeRebaseMerge": false,
      "requireLinearHistory": false,
      "requireSignedCommits": false
    }
  ],
  "policyReconciliation": {
    "trustedPolicySource": "POLICY_SHA",
    "effectiveContract": "union-of-policy-and-head-additions",
    "headMayAdd": [
      "owner-paths",
      "required-proof-mappings",
      "focused-obligations",
      "proof-owners",
      "scenario-fixtures",
      "proof-ids",
      "challenge-proposals"
    ],
    "headMayNotWeaken": [
      "owner-paths",
      "required-proof-mappings",
      "focused-obligations",
      "proof-ownership",
      "quarantines",
      "protected-challenges"
    ],
    "newSamePullRequestFeatures": "fallback-proof-required-until-merged"
  },
  "featureContracts": {
    "source": "docs/feature-proofs.yml",
    "activationReasons": [
      "owner-path-change",
      "required-proof-owner-change",
      "scenario-fixture-change",
      "validation-declaration-change",
      "challenge-declaration-change",
      "semantic-registry-change",
      "durable-proof-id-owner-change",
      "trusted-e2e-spec-change"
    ],
    "proofIdDiscovery": [
      "restricted-file-header",
      "declarative-sidecar-manifest",
      "statically-parsed-allowlisted-helper-call"
    ]
  },
  "commandModel": {
    "freeFormShell": false,
    "commandKinds": [
      "protected-stage",
      "vitest",
      "playwright",
      "head-lint",
      "head-typecheck",
      "head-build",
      "sensitivity-challenge"
    ],
    "protectedStages": [
      "registry-validation",
      "feature-proof-validation",
      "proof-id-validation",
      "test-quality-validation",
      "animation-validation",
      "ability-contract-validation",
      "export-shape-validation"
    ]
  },
  "globalValidation": {
    "fullSuiteFallback": "non-bailing",
    "stages": [
      "protected-registry-validation",
      "protected-feature-proof-validation",
      "protected-proof-id-validation",
      "protected-test-quality-validation",
      "protected-animation-validation",
      "protected-ability-contract-validation",
      "head-lint",
      "head-typecheck",
      "head-full-non-bailing-vitest-suite",
      "head-build",
      "protected-export-shape-validation"
    ]
  },
  "globalExactSpecRules": {
    "changedE2eSpec": "run-exact-spec-under-protected-project-set",
    "changedPlaywrightSupportPath": "run-browser-smoke-scenario-and-renderer-suites",
    "changedScenarioFixture": "run-scenario-fixture-contract-and-scenario-e2e-suite",
    "changedSharedPlaywrightConfiguration": "run-browser-smoke-scenario-and-renderer-suites",
    "changedBrowserAdapterOrMetadata": "run-browser-smoke-scenario-and-renderer-suites"
  },
  "fallbackProofMapping": {
    "general-contract": "protected-non-bailing-full-vitest-suite",
    "core-runtime": "protected-non-bailing-full-vitest-suite",
    "feature-chain": "protected-non-bailing-full-vitest-suite",
    "presenter": "protected-non-bailing-full-vitest-suite",
    "web-ui": "protected-non-bailing-full-vitest-suite",
    "content-id": "protected-content-cross-reference-contract",
    "ability": "protected-ability-contract-stage",
    "animation-or-three-rendering": "protected-animation-stage-and-renderer-e2e-suite",
    "persistence": "save-compatibility-tests-and-save-snapshot-scenario-contracts",
    "browser-facing": "scenario-e2e-suite"
  },
  "repositoryDrift": {
    "checkpoints": [
      "clean-checkout",
      "post-install-pre-proof",
      "post-proof"
    ],
    "gitignoreBoundsVisibility": false,
    "dependencyRoots": "read-only-with-digest",
    "installOutputAllowlist": [
      ".pnpm-store/**"
    ],
    "proofOutputAllowlist": [
      ".validate-logs/**",
      "test-results/**",
      "playwright-report/**"
    ],
    "allowlistNeverExempts": [
      "tracked-file-modification",
      "tracked-file-deletion",
      "tracked-mode-change",
      "tracked-type-change",
      "preexisting-boundary-path"
    ]
  },
  "landingCommit": {
    "commitObject": "deterministic-service-owned-merge-commit",
    "firstParent": "POLICY_SHA",
    "secondParent": "PR_HEAD_SHA",
    "tree": "GITHUB_MERGE_TREE_SHA",
    "signature": "none",
    "author": {
      "name": "Crawler Proof Verifier",
      "email": "crawler-proof-verifier@noreply.github.com"
    },
    "committer": {
      "name": "Crawler Proof Verifier",
      "email": "crawler-proof-verifier@noreply.github.com"
    },
    "authorDate": "pr-head-author-date-utc",
    "committerDate": "policy-sha-committer-date-plus-one-second-utc",
    "messageTemplate": "Attested merge of {PR_HEAD_SHA} onto {POLICY_SHA}\n"
  },
  "attestationIdentities": [
    "POLICY_SHA",
    "PR_HEAD_SHA",
    "MERGE_BASE_SHA",
    "GITHUB_MERGE_TREE_SHA",
    "LANDING_COMMIT_SHA",
    "EVALUATED_TREE_SHA"
  ],
  "policyRetirement": {
    "mode": "planned-authoritative-policy-retirement-validation-after-pr0b-pr0c",
    "changedPaths": "allowlisted-policy-files-only",
    "requiresCodeownersApprovalBoundToPrHeadSha": true,
    "mixedPolicyAndImplementationChange": "rejected"
  },
  "localWorkflow": [
    "install-proofctl-v0.4.2-from-github.com/mcmiv413/agent-verifier-release-v0.4.2",
    "verify-proofctl-artifact-digest",
    "develop-and-run-targeted-tests",
    "proofctl plan --repository PATH --base BASE_SHA --head HEAD_SHA",
    "review-selected-obligations",
    "run-local-validation-gates",
    "commit-and-push-branch",
    "open-draft-pull-request",
    "await-pr0b-pr0c-for-authoritative-validation-attestation-and-merge-admission"
  ]
}
